# Copy to /opt/ibokki/.env and fill in. Loaded by the systemd unit.

# Public origin — used in verification/reset mail links.
IBOKKI_BASE_URL=https://ibokki.com
# Cookies are Secure behind Caddy's TLS.
IBOKKI_SECURE_COOKIES=1
# SQLite database file (back this one file up).
IBOKKI_DB=/opt/ibokki/data/ibokki.db

# --- Robustness knobs (all optional; sensible defaults shown) ---
# A dropped seat has this long (ms) to rejoin before it forfeits the match.
#IBOKKI_DISCONNECT_GRACE_MS=45000
# A connected but idle player forfeits after this long (ms) with no action.
#IBOKKI_INACTIVITY_MS=300000
# Hard cap on concurrent rooms (memory backstop).
#IBOKKI_MAX_ROOMS=5000
# Per-connection WS message rate limit: burst capacity + steady refill/sec.
#IBOKKI_MSG_BURST=200
#IBOKKI_MSG_REFILL_PER_SEC=100
# Comma-separated allowed WebSocket Origins (CSWSH guard). Unset ⇒ allow all.
#IBOKKI_ALLOWED_ORIGINS=https://ibokki.com

# Optional SSO via the ibokki.com site (django-oauth-toolkit provider).
# When set, "Sign in with ibokki.com" replaces local registration.
# See deploy/site-integration/README.md for the full /play mount.
#IBOKKI_OIDC_ISSUER=https://ibokki.com/o
#IBOKKI_OIDC_CLIENT_ID=
#IBOKKI_OIDC_CLIENT_SECRET=
#IBOKKI_OIDC_REDIRECT_URI=https://ibokki.com/play/api/auth/oidc/callback
#IBOKKI_PUBLIC_PATH=/play/

# ProtonMail SMTP — same values as the ibokkiSite Django app.
# (Only used for LOCAL accounts' verification/reset mails; unused under SSO.)
EMAIL_HOST=smtp.protonmail.ch
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@ibokki.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ibokki.com
