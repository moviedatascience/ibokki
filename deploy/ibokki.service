# systemd unit for the Ibokki online server.
#   sudo cp deploy/ibokki.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now ibokki
[Unit]
Description=Ibokki online game server
After=network.target

[Service]
Type=simple
User=ibokki
WorkingDirectory=/opt/ibokki
EnvironmentFile=/opt/ibokki/.env
ExecStart=/usr/bin/node --import tsx apps/server/src/server.ts
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
